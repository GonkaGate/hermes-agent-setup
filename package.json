{
  "name": "@gonkagate/hermes-agent-setup",
  "version": "0.2.0",
  "description": "GonkaGate onboarding helper for configuring Hermes Agent.",
  "homepage": "https://github.com/GonkaGate/hermes-agent-setup#readme",
  "bugs": {
    "url": "https://github.com/GonkaGate/hermes-agent-setup/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GonkaGate/hermes-agent-setup.git"
  },
  "type": "module",
  "bin": {
    "hermes-agent-setup": "bin/gonkagate-hermes-agent-setup.js",
    "gonkagate-hermes-agent-setup": "bin/gonkagate-hermes-agent-setup.js"
  },
  "files": [
    "bin",
    "dist",
    "docs",
    "scripts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package:check": "publint",
    "prepack": "npm run ci",
    "qualification:artifact:build": "node scripts/launch-qualification/build-artifact.mjs",
    "qualification:artifact:validate": "node scripts/launch-qualification/validate-artifacts.mjs",
    "qualification:prepare": "npm run build && node scripts/launch-qualification/prepare-clean-home.mjs",
    "test": "npm run build && node scripts/run-tests.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "ci": "npm run typecheck && npm run test && npm run qualification:artifact:validate && npm run format:check && npm run package:check"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "keywords": [
    "gonkagate",
    "hermes-agent",
    "hermes",
    "installer",
    "onboarding",
    "cli",
    "openai-compatible"
  ],
  "license": "Apache-2.0",
  "packageManager": "npm@11.11.1",
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@types/semver": "^7.7.1",
    "@types/write-file-atomic": "^4.0.3",
    "prettier": "^3.6.2",
    "publint": "^0.3.15",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "commander": "^14.0.3",
    "semver": "^7.7.3",
    "write-file-atomic": "^7.0.1",
    "yaml": "^2.8.1"
  }
}
